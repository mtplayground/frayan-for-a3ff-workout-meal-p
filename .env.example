# PostgreSQL is required for all persistent state. Plain postgresql:// URLs are also accepted.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/app_db

# FastAPI runtime settings.
APP_NAME=Workout Meal Planner API
ENVIRONMENT=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
ALLOWED_CORS_ORIGIN=
SELF_URL=
CORS_ALLOW_CREDENTIALS=true

# Vite build-time setting. For self-hosting, set this before npm run build:frontend.
VITE_API_BASE_URL=http://localhost:8080/api
